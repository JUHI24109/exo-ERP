<IfModule mod_rewrite.c>
RewriteEngine On

# Route all /api/ requests directly to Node.js via mod_proxy
RewriteRule ^api/(.*)$ http://127.0.0.1:5000/api/$1 [P,L]

# Proxy WebSocket requests to Node.js backend
RewriteRule ^socket\.io/(.*)$ http://127.0.0.1:5000/socket.io/$1 [P,L]

# Serve uploaded files from backend
RewriteRule ^uploads/(.*)$ backend/uploads/$1 [L]
</IfModule>

# Increase PHP timeout for deploy scripts
<IfModule mod_php.c>
php_value max_execution_time 300
</IfModule>
