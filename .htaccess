RewriteEngine On

# If the request is for an actual file in frontend/, serve it directly
RewriteCond %{REQUEST_URI} !^/frontend/
RewriteCond %{REQUEST_URI} !^/backend/
RewriteCond %{REQUEST_URI} !^/uploads/
RewriteCond %{REQUEST_URI} !^/node_modules/

# Rewrite all requests to frontend/ folder
RewriteRule ^(.*)$ frontend/$1 [L]

# Set index.html as the default document
DirectoryIndex index.html

# Disable PHP processing for HTML files
<FilesMatch "\.html$">
    SetHandler default-handler
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Handle 404 errors
ErrorDocument 404 /frontend/index.html
