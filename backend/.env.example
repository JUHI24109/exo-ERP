# =======================================
# EXO-ERP Backend — Environment Config
# =======================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- Server ----
PORT=5000
JWT_SECRET=exo-erp-secret-key-change-this-in-production

# ---- MySQL Database (Cloudways) ----
# Go to Cloudways > Application Settings > Access Details
# Copy: DB Name, DB Username, DB Password
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database_name_here
DB_USERNAME=your_database_username_here
DB_PASSWORD=your_database_password_here
DB_DIALECT=mysql

# ---- PostgreSQL (Alternative - if using Postgres instead) ----
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# ---- Twilio (Optional — for WhatsApp OTP) ----
# TWILIO_SID=your_twilio_sid
# TWILIO_TOKEN=your_twilio_token
# TWILIO_PHONE=whatsapp:+14155238886

# ---- Email (Optional — for notifications) ----
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
